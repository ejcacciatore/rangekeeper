# RangeKeeper Backend Configuration

# Server
PORT=3000
NODE_ENV=development

# Database
DATABASE_PATH=./data/rangekeeper.db

# Discord Bot (optional)
DISCORD_BOT_TOKEN=your_discord_bot_token_here
DISCORD_USER_ID=your_discord_user_id_here

# Web Push (optional, for PWA notifications)
VAPID_PUBLIC_KEY=your_vapid_public_key
VAPID_PRIVATE_KEY=your_vapid_private_key
VAPID_SUBJECT=mailto:your_email@example.com

# Twilio (optional, for SMS alerts)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=your_twilio_phone_number
STUDENT_PHONE_NUMBER=student_phone_number

# M365 Graph API (optional, for email/calendar sync)
AZURE_CLIENT_ID=your_azure_app_client_id
AZURE_CLIENT_SECRET=your_azure_app_client_secret
AZURE_TENANT_ID=your_azure_tenant_id

# Blackboard API (optional, for 3LO OAuth)
BLACKBOARD_APP_KEY=your_blackboard_app_key
BLACKBOARD_APP_SECRET=your_blackboard_app_secret
BLACKBOARD_BASE_URL=https://ualearn.blackboard.com
