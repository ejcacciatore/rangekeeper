# =============================================================================
# RangeKeeper — Environment Variables
# Copy this file to .env.local and fill in the values.
# Never commit .env.local to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
# PostgreSQL connection string (Docker default below)
DATABASE_URL="postgresql://rangekeeper:rangekeeper_dev@localhost:5432/rangekeeper?schema=public"

# -----------------------------------------------------------------------------
# Redis (BullMQ queues)
# -----------------------------------------------------------------------------
REDIS_URL="redis://localhost:6379"

# -----------------------------------------------------------------------------
# NextAuth.js
# -----------------------------------------------------------------------------
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="your-nextauth-secret-here"
NEXTAUTH_URL="http://localhost:3000"

# -----------------------------------------------------------------------------
# OpenAI
# -----------------------------------------------------------------------------
OPENAI_API_KEY="sk-..."
# Optional: override the default model
OPENAI_MODEL="gpt-4o"

# -----------------------------------------------------------------------------
# Twilio (SMS nudges)
# -----------------------------------------------------------------------------
TWILIO_ACCOUNT_SID="ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
TWILIO_AUTH_TOKEN="your-twilio-auth-token"
TWILIO_PHONE_NUMBER="+15550001234"

# -----------------------------------------------------------------------------
# Canvas LMS
# -----------------------------------------------------------------------------
CANVAS_API_KEY="your-canvas-api-token"
CANVAS_BASE_URL="https://your-institution.instructure.com"

# -----------------------------------------------------------------------------
# Google OAuth (for NextAuth Google provider)
# -----------------------------------------------------------------------------
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# -----------------------------------------------------------------------------
# App
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# -----------------------------------------------------------------------------
# Optional / Future
# -----------------------------------------------------------------------------
# MICROSOFT_CLIENT_ID=""
# MICROSOFT_CLIENT_SECRET=""
# SENTRY_DSN=""
# RESEND_API_KEY=""       # For email notifications (alternative to Twilio)
