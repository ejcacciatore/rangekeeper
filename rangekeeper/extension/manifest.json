{
  "manifest_version": 3,
  "name": "RangeKeeper",
  "version": "0.2.0",
  "description": "Academic success companion for neurodivergent college students. Tracks assignments, grades, messages, and deadlines from Blackboard Learn.",
  "permissions": [
    "storage",
    "notifications",
    "alarms",
    "tabs"
  ],
  "host_permissions": [
    "https://ualearn.blackboard.com/*",
    "https://*.blackboard.com/*",
    "https://*.cstp.blackboard.com/*",
    "http://localhost:3000/*"
  ],
  "background": {
    "service_worker": "scripts/background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://ualearn.blackboard.com/*",
        "https://*.blackboard.com/*",
        "https://*.cstp.blackboard.com/*"
      ],
      "js": [
        "scripts/utils.js",
        "scripts/grades-scraper.js",
        "scripts/messages-scraper.js",
        "scripts/content.js"
      ],
      "run_at": "document_idle"
    },

  ],
  "web_accessible_resources": [
    {
      "resources": ["scripts/utils.js", "scripts/devtools-bridge.js"],
      "matches": [
        "https://ualearn.blackboard.com/*",
        "https://*.blackboard.com/*",
        "https://*.cstp.blackboard.com/*"
      ]
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
